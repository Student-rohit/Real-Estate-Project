# Dependency directories (The biggest cause of Render errors)
node_modules/
*/node_modules/
client/node_modules/
api/node_modules/

# Production builds
dist/
client/dist/
build/

# Environment variables (Security risk - keep these secret!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
api/.env

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.log

# Operating System files
.DS_Store
Thumbs.db

# Editor / IDE folders
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# Vercel / Netlify / Render build folders
.vercel
.netlify
.render